{
  "id": "./",
  "name": "Lumiéra — Illuminate Your Natural Beauty",
  "short_name": "Lumiéra",
  "description": "Pengalaman beauty-tech berbasis AI dengan Face Scan, Virtual Makeup, GlowUp Academy, dan SkinGlow Tracker untuk memancarkan kecantikan alami Anda.",
  "start_url": "./index.html",
  "scope": "./",
  "display": "standalone",
  "background_color": "#090607",
  "theme_color": "#E8B4B8",
  "orientation": "portrait",
  "lang": "id",
  "categories": [
    "beauty",
    "lifestyle",
    "health"
  ],
  "file_handlers": [
    {
      "action": "./index.html",
      "accept": {
        "image/*": [".jpg", ".jpeg", ".png", ".webp"]
      }
    }
  ],
  "launch_handler": {
    "client_mode": "focus-existing"
  },
  "protocol_handlers": [
    {
      "protocol": "web+lumiera",
      "url": "./index.html?uri=%s"
    }
  ],
  "prefer_related_applications": false,
  "related_applications": [
    {
      "platform": "webapp",
      "url": "https://ethereallkat.github.io/lumiera/manifest.json"
    },
    {
      "platform": "play",
      "url": "https://play.google.com/store/apps/details?id=com.lumiera.app",
      "id": "com.lumiera.app"
    }
  ],
  "share_target": {
    "action": "./index.html",
    "method": "GET",
    "params": {
      "title": "title",
      "text": "text",
      "url": "url"
    }
  },
  "icons": [
    {
      "src": "icons/icon-192x192-A.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "any maskable"
    },
    {
      "src": "icons/icon-512x512-B.png",
      "sizes": "512x512",
      "type": "image/png"
    }
  ],
  "screenshots": [
    {
      "src": "icons/screenshot1.png",
      "sizes": "1080x1920",
      "type": "image/png",
      "label": "Dashboard Lumiéra"
    }
  ],
  "shortcuts": [
    {
      "name": "Face Scan",
      "short_name": "Scan",
      "url": "./index.html#screen-scan",
      "description": "Analisis kondisi kulit wajah Anda",
      "icons": [{ "src": "icons/shortcut-scan.png", "sizes": "96x96" }]
    },
    {
      "name": "Virtual Makeup",
      "short_name": "Makeup",
      "url": "./index.html#screen-makeup",
      "description": "Coba berbagai tampilan makeup secara virtual",
      "icons": [{ "src": "icons/shortcut-makeup.png", "sizes": "96x96" }]
    },
    {
      "name": "Skin Tracker",
      "short_name": "Tracker",
      "url": "./index.html#screen-tracker",
      "description": "Pantau progres kesehatan kulit harian",
      "icons": [{ "src": "icons/shortcut-tracker.png", "sizes": "96x96" }]
    }
  ]
}
